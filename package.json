{
  "name": "vreport",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "ci": "npm run typecheck && npm run lint && npm run test"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.3",
    "dayjs": "^1.11.11",
    "dexie": "^4.0.7",
    "echarts": "^5.5.0",
    "exceljs": "^4.4.0",
    "html2canvas": "^1.4.1",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "lodash-es": "^4.17.21",
    "papaparse": "^5.4.1",
    "pinia": "^2.1.7",
    "qrcode": "^1.5.4",
    "vue": "^3.4.27",
    "vue-router": "^4.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/lodash-es": "^4.17.12",
    "@types/papaparse": "^5.3.14",
    "@types/qrcode": "^1.5.6",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^2.0.5",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.9.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.27.0",
    "fake-indexeddb": "^6.2.5",
    "globals": "^15.9.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.2.11",
    "vitest": "^2.0.5",
    "vue-tsc": "^2.0.19"
  }
}
